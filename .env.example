NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
ANTHROPIC_API_KEY=
# Google AI Studio — creativos (Gemini / Nano Banana). Solo servidor.
GEMINI_API_KEY=
# Opcional: forzar modelo y resolución en el servidor (ignora selección del cliente)
# GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
# GEMINI_IMAGE_SIZE=1K
#
# Producción: sin GEMINI_IMAGE_SIZE, el servidor usa siempre 1K (coste predecible).
# Para permitir 2K/4K desde la UI en un deploy (staging), ambas en true:
# GEMINI_ALLOW_IMAGE_SIZE_OPTIONS=true
# NEXT_PUBLIC_GEMINI_ALLOW_IMAGE_SIZE_OPTIONS=true
